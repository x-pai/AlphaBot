# 应用配置
APP_NAME="AI Stock Assistant API"
API_V1_STR="/api/v1"

# 数据源配置
# 可选值: "alphavantage", "tushare", "akshare", "hk_stock", "tdx"
DEFAULT_DATA_SOURCE="akshare"

# Alpha Vantage API配置
ALPHAVANTAGE_API_BASE_URL="https://www.alphavantage.co/query"
ALPHAVANTAGE_API_KEY="your_alphavantage_api_key"

# Tushare API配置
TUSHARE_API_TOKEN="your_tushare_api_token"

# AKShare配置
AKSHARE_USE_PROXY=False
AKSHARE_PROXY_URL=""

# 雪球配置（用于AKShare的部分接口）
XUEQIU_TOKEN="your_xueqiu_token"

# TDX 配置
TDX_API_BASE_URL="http://your-tdx-api-host"
TDX_TIMEOUT=10

# 数据库配置
DATABASE_URL="sqlite:///./stock_assistant.db"

# 安全配置
SECRET_KEY="your-secret-key-for-production"

# AI分析配置
# 可选值: "rule", "ml", "llm"
DEFAULT_ANALYSIS_MODE="rule"

# AI模型配置
AI_MODEL_PATH="./models/stock_analysis_model.pkl"

# LLM 配置（LiteLLM 统一接口）
# 模型格式：provider/model_name，如 openai/gpt-4o-mini、deepseek/deepseek-chat、anthropic/claude-3-5-sonnet
LLM_MODEL="openai/gpt-4o-mini"
LLM_API_KEY="your_api_key"
LLM_API_BASE="https://api.openai.com/v1"
LLM_MAX_TOKENS=1000
LLM_TEMPERATURE=0.7
# 可选：逗号分隔的可用模型列表，供前端切换
LLM_AVAILABLE_MODELS=openai/gpt-4o-mini,openai/gpt-4o

# 向量检索 / 长期记忆配置（Chroma + Embedding）
# 默认使用 OpenAI 兼容 embedding
EMBEDDING_MODEL="text-embedding-3-small"
# 可选：单独为向量检索配置 provider，不填则回退到 LLM_API_BASE / LLM_API_KEY
EMBEDDING_API_BASE=""
EMBEDDING_API_KEY=""

# 可选：为不同角色指定专用模型（未配置则回退到上面的 LLM_*）
# LLM_DEFAULT_MODEL="openai/gpt-4o-mini"
# LLM_RESEARCH_MODEL="openai/gpt-4o-mini"
# LLM_RISK_MODEL="openai/gpt-4o-mini"

# 飞书渠道配置
FEISHU_APP_ID=""
FEISHU_APP_SECRET=""
FEISHU_API_BASE="https://open.feishu.cn"
FEISHU_VERIFICATION_TOKEN=""
FEISHU_ENCRYPT_KEY=""

# CORS配置
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000", "http://frontend:3000", "http://backend:8000"]

# Redis和Celery配置
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0 

# 搜索引擎配置（2000积分可用）
# 可选值：serpapi, googleapi, bingapi
# SEARCH_API_ENABLED=True
# SEARCH_ENGINE=serpapi
# SERPAPI_API_KEY=你的SerpAPI密钥
